# ---- Data (large, not in VCS) ----
data/*
!data/claude_trajectory/
eval_local/
artifacts/
kddcup2026-starter-kit/data
kddcup2026-starter-kit/data/
kddcup2026-starter-kit/artifacts/
data_agent_v0/artifacts/
data_agent_baseline_v1/artifacts/
tools/agent_diagnose/artifacts/

# ---- Docker submission artifacts ----
*.tar.gz
data_agent_baseline_v1/.smoke/
data_agent_baseline_v1/.verify_full/
data_agent_baseline_v1/.pipeline_logs/

# ---- Run logs ----
data_agent_v0/run_*.log
data_agent_baseline_v1/run_*.log

# ---- Secrets (NEVER commit) ----
.env
.env.*
!.env.example
config/*.pem
config/*.key
*.runtime.yaml
*.local.yaml

# ---- Intermediate / regeneratable ----
reports/_baseline_summary.json

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.python-version
dist/
build/
*.egg-info/

# ---- uv / pip caches ----
.uv_cache/
# uv.lock 是锁文件，必须提交以保证 docker build 可复现

# ---- Tooling ----
.mypy_cache/
.ruff_cache/
.pytest_cache/

# ---- Editor / OS ----
.DS_Store
.vscode/
.idea/
*.swp
*~

# ---- Claude Code session ----
.claude/
.playwright-mcp/
# Per-developer local context (identity + current focus); see CLAUDE.md "Per-developer identity"
# Each teammate keeps their own CLAUDE.local.<name>.md on the shared server.
# The .example template is committed; per-user files are not.
CLAUDE.local.*.md
!CLAUDE.local.md.example

# ---- 3-seed 控制脚本日志（运行时产物，非评测结果） ----
reports/_3seed_logs/master*.log

# ---- 早期 server-side 3-seed 运行产物（mbp 主线只入 v0_v5_F1F2tuned 系列） ----
# 已 commit 的 v0_v5_F1F2tuned* 不受影响（gitignore 不撤销已 tracked 文件）
reports/_3seed_logs/baseline*.log
reports/_3seed_logs/v0_3seed_remote*.log
reports/demo_qwen35_baseline_remote*_scored.json
reports/demo_qwen35_baseline_v1_remote*_scored.json
reports/demo_qwen35_v0_remote*_scored.json
reports/docker_verify_*_scored.json

# ---- diagnose tool runtime（pid / nohup log） ----
tools/agent_diagnose/.diagnose.pid
tools/agent_diagnose/diagnose.log

# ---- 各 agent 包内 data 软链 (->../data, gitignored)，避免误提交悬空链接 ----
data_agent_v0/data
data_agent_baseline_v1/data

# ---- 临时文件 ----
*.bak
*.local.yaml.bak

# ---- 根目录散落截图（按需手动 git add） ----
/*.png
